{
  "expo": {
    "name": "BetaDriva",
    "slug": "betadriva",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "scheme": "betadriva",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omolasofrancis.batagroup"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.omolasofrancis.batagroup"
    },
    "web": {
      "output": "single",
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/TTCommons-Light.otf",
            "./src/assets/fonts/TTCommons-Regular.otf",
            "./src/assets/fonts/TTCommons-Medium.otf",
            "./src/assets/fonts/TTCommons-DemiBold.otf",
            "./src/assets/fonts/TTCommons-Bold.otf",
            "./src/assets/fonts/TTCommons-ExtraBold.otf",
            "./src/assets/fonts/TTCommons-Black.otf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8137600d-8fe3-4041-8fe3-293c2c834c32"
      }
    }
  }
}
